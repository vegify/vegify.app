{
  "name": "vegify",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "@tailwindcss/oxide",
      "sharp"
    ],
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "^0.25.0"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @vegify/db push",
    "db:seed": "pnpm --filter @vegify/db seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@tailwindcss/cli": "^4.3.2",
    "turbo": "^2.10.5"
  }
}

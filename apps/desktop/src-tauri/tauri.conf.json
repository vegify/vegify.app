{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "vegify",
  "version": "0.11.0",
  "identifier": "app.vegify.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "beforeBundleCommand": "node scripts/ensure-provisionprofile.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Vegify",
        "width": 1280,
        "height": 832,
        "minWidth": 1024,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "vegify"
        ]
      },
      "mobile": [
        {
          "scheme": [
            "vegify"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "files": {
        "embedded.provisionprofile": "embedded.provisionprofile"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}

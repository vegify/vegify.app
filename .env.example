# vegify.app — environment configuration template
#
# Copy to `.env` and fill in for your own deployment. Every value has an inert default in code, so a fresh
# clone builds + `cdk synth`s without this file — you only set what your real deploy uses. Real `.env`
# files are gitignored; this `.example` is the only one committed.
#
# This file covers deploy-time + server runtime config. The GitHub Actions secrets that drive CI releases
# are a separate list — see docs/self-host.md.

# ── AWS / CDK (infra) ──────────────────────────────────────────────────────────────────────────────────
CDK_DEFAULT_ACCOUNT=                    # your 12-digit AWS account id (cdk fills this from your credentials)
CDK_DEFAULT_REGION=us-east-1            # deploy region; VEGIFY_SES_REGION must match for email to verify
GITHUB_REPOSITORY=your-org/your-repo    # owner/repo for the CI OIDC trust (auto-set inside GitHub Actions)

# ── Domain + TLS ───────────────────────────────────────────────────────────────────────────────────────
VEGIFY_DOMAIN_NAMES=example.com,www.example.com   # the web shell's domains (first is primary)
VEGIFY_HOSTED_ZONE_ID=ZEXAMPLE00000000            # Route53 hosted zone id for your domain
# CloudFront requires the cert in us-east-1, regardless of CDK_DEFAULT_REGION:
VEGIFY_CERT_ARN=arn:aws:acm:us-east-1:123456789012:certificate/00000000-0000-0000-0000-000000000000

# ── Web shell → backend ────────────────────────────────────────────────────────────────────────────────
VEGIFY_API_URL=https://api.example.com    # the Axum backend origin the web SSR (and desktop) call over HTTP
VEGIFY_INGEST_ORIGIN=ingest.example.com   # client-log ingestion origin (VegifyClientLogs)
VITE_CLIENT_LOG_URL=                      # browser-log Function URL (VegifyClientLogs output), baked into the web build

# ── Origin hardening (defense-in-depth; empty = off, fail-open, never breaks the app) ──────────────────
ORIGIN_VERIFY_SECRET=                     # shared secret CloudFront injects + the Lambdas/server require; the server reads it as ORIGIN_SECRET

# ── Server (Axum) runtime ──────────────────────────────────────────────────────────────────────────────
DATABASE_PATH=                # on-disk SQLite/libSQL file the server opens (dev: .data/vegify.db; prod: the EBS-backed file)
DATABASE_URL=                 # OR a remote libSQL/Turso URL (libsql://…) instead of a local file
DATABASE_AUTH_TOKEN=          # auth token, if your DATABASE_URL needs one
PORT=8787                     # server listen port
VEGIFY_PUBLIC_URL=https://example.com          # public base URL used in email links (reset / verify)
VEGIFY_SIGNUPS_OPEN=0                           # "1" allows new signups; anything else rejects them
VEGIFY_EMAIL_FROM=Vegify <hello@example.com>   # From: header for transactional mail

# ── Email / SES (VegifyEmail) ──────────────────────────────────────────────────────────────────────────
VEGIFY_SES_REGION=us-east-1            # region where the SES identity is verified (the server sends here)
VEGIFY_EMAIL_DOMAIN=                   # domain for the SES identity (defaults to the first VEGIFY_DOMAIN_NAMES)
VEGIFY_MAIL_FROM_DOMAIN=               # custom MAIL FROM subdomain (defaults to mail.<domain>)
VEGIFY_TEST_EMAIL=                     # recipient for the ignored live SES send test only

# ── Desktop (Tauri) ────────────────────────────────────────────────────────────────────────────────────
# VEGIFY_API_URL is baked at BUILD time into the desktop binary; VEGIFY_AUTH_URL overrides it at RUNTIME
# (e.g. `tauri dev` against a real backend). DATABASE_PATH overrides the on-device db path.
VEGIFY_AUTH_URL=                       # runtime backend override for the desktop (else the baked VEGIFY_API_URL)
